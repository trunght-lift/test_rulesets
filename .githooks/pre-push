#!/usr/bin/env bash
# pre-push hook: chạy OpenHands code review trước khi push
# Flow: build diff → openhands CLI headless --json → parse verdict
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
PARSE_SCRIPT="$REPO_ROOT/scripts/parse_review.py"
LOG_FILE="$REPO_ROOT/.openhands-review.log"

# Load .env an toàn (chỉ export key=value, bỏ qua comment và dòng trống)
if [ -f "$REPO_ROOT/.env" ]; then
    while IFS='=' read -r key value; do
        # Bỏ qua comment và dòng trống
        [[ "$key" =~ ^#.*$ ]] && continue
        [[ -z "$key" ]] && continue
        # Export biến (strip quotes nếu có)
        value="${value%\"}"
        value="${value#\"}"
        export "$key=$value"
    done < <(grep -v '^#' "$REPO_ROOT/.env" | grep -v '^$')
fi

# ── 1. Lấy diff của commits sắp push ─────────────────────────────────────────
# stdin của pre-push: "<local_ref> <local_sha1> <remote_ref> <remote_sha1>"
DIFF=""
while read -r local_ref local_sha remote_ref remote_sha; do
    if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
        continue  # branch bị xóa, bỏ qua
    fi

    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        # Branch mới, diff toàn bộ
        DIFF+=$(git diff --unified=3 "$(git rev-list --max-parents=0 HEAD)"..HEAD 2>/dev/null || git show --unified=3 "$local_sha")
    else
        DIFF+=$(git diff --unified=3 "$remote_sha".."$local_sha")
    fi
done

if [ -z "$DIFF" ]; then
    echo "[pre-push] Không có thay đổi code, bỏ qua review."
    exit 0
fi

# Giới hạn diff để không vượt context window (~8000 chars)
DIFF_TRUNCATED="${DIFF:0:8000}"
if [ ${#DIFF} -gt 8000 ]; then
    DIFF_TRUNCATED+=$'\n\n[... diff bị cắt bớt do quá dài ...]'
fi

# ── 2. Build prompt ───────────────────────────────────────────────────────────
TASK="You are a technical lead reviewing code changes before they go into the codebase.

Review the following git diff and provide your assessment:

BLOCKING ISSUES (must REJECT):
- Syntax errors in any language (e.g., typos like 'prin' instead of 'print', malformed statements like 'a = int 1')
- Runtime errors (undefined variables, incorrect function calls)
- Security vulnerabilities (hardcoded secrets, API keys, SQL injection)
- Critical logic errors that cause crashes or data loss
- Gibberish/test code with multiple errors

NON-BLOCKING ISSUES (can APPROVE):
- Code runs without errors
- Minor code smells that don't affect functionality
- Formatting or naming convention issues

Provide a brief technical assessment of the changes, then conclude with your decision on a separate line:
APPROVE  (if code is functional and safe to merge)
REJECT   (if blocking issues exist)

Write your review in a direct, professional tone as a technical lead would - state facts, identify issues clearly, and make a decisive call.

--- GIT DIFF ---
$DIFF_TRUNCATED
--- END DIFF ---"

# ── 3. Kiểm tra OpenHands CLI ────────────────────────────────────────────────
if ! command -v openhands &> /dev/null; then
    echo "[pre-push] OpenHands CLI chưa cài đặt."
    echo "           Cài đặt: pip install openhands-ai"
    echo "           Hoặc: pipx install openhands-ai"
    echo "           Bỏ qua review, tiếp tục push..."
    exit 0
fi

# Kiểm tra API key
if [ -z "${LLM_API_KEY:-}" ]; then
    echo "[pre-push] LLM_API_KEY chưa được set trong .env"
    echo "           Bỏ qua review, tiếp tục push..."
    exit 0
fi

# ── 4. Chạy OpenHands headless ────────────────────────────────────────────────
echo "[pre-push] Đang chạy OpenHands code review..."

REVIEW_OUTPUT=$(openhands --headless --json --always-approve \
    --override-with-envs \
    -t "$TASK" 2>&1) || true

# Chỉ lưu log nếu có env DEBUG=1 (tránh lộ thông tin nhạy cảm)
if [ "${DEBUG:-1}" = "1" ]; then
    echo "$REVIEW_OUTPUT" > "$LOG_FILE"
    echo "[debug] Output đã lưu vào $LOG_FILE" >&2
fi

# ── 5. Parse verdict ──────────────────────────────────────────────────────────
echo "$REVIEW_OUTPUT" | python3 "$PARSE_SCRIPT"
PARSE_EXIT_CODE=$?

# Exit với code từ parse script (0 = approve, 1 = reject)
exit $PARSE_EXIT_CODE
