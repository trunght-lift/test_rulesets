{
  "pre_tool_use": [
    {
      "matcher": "terminal",
      "hooks": [
        {
          "command": ".openhands/hooks/block_dangerous.sh",
          "timeout": 10
        }
      ]
    }
  ],
  "stop": [
    {
      "matcher": "*",
      "hooks": [
        {
          "command": ".openhands/hooks/require_checks.sh",
          "timeout": 180
        }
      ]
    }
  ]
}
